{
  "name": "@pizzaerp/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.1.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.6.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
