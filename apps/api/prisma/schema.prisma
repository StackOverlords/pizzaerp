generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Global schema (public) ───────────────────────────────────────────────────
// Tenant-specific tables (orders, menu, shifts...) live in dynamic schemas
// created by TenantSchemaService. Managed via raw SQL migrations, not Prisma.

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  maxBranches   Int?                    // null = ilimitado
  maxUsers      Int?                    // null = ilimitado
  features      Json     @default("[]") // ["inventory", "reports", ...]
  priceMonthly  Decimal? @db.Decimal(10, 2) // null = licencia perpetua
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @unique
  planId           String
  status           SubscriptionStatus @default(TRIAL)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?          // null = licencia perpetua
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  schema       String       @unique
  status       TenantStatus @default(ONBOARDING)
  billingEmail String?
  createdAt    DateTime     @default(now())

  subscription Subscription?
  branches     Branch[]
  users        User[]
}

model Branch {
  id       String @id @default(cuid())
  name     String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  username     String
  passwordHash String
  role         Role
  tenantId     String
  branchId     String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([username, tenantId])
}

enum Role {
  ADMIN
  CAJERO
  HORNERO
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}
